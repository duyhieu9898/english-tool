{
  "name": "lingo-me",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "license": "MIT",
  "author": "Hieu Nguyen",
  "description": "LingoMe is a web application for learning English.",
  "scripts": {
    "dev": "concurrently \"yarn dev:fe\" \"yarn dev:be\"",
    "dev:fe": "vite",
    "dev:be": "cd backend && nodemon server.js",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "format": "prettier --write .",
    "preview": "vite preview",
    "test": "vitest",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@google/genai": "^1.49.0",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-query-devtools": "^5.91.3",
    "@types/canvas-confetti": "^1.9.0",
    "axios": "^1.13.6",
    "canvas-confetti": "^1.9.4",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "framer-motion": "^12.34.3",
    "json-server": "^1.0.0-beta.12",
    "lucide-react": "^0.575.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.13.1",
    "tailwindcss": "^4.2.1"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.0.2",
    "@eslint/js": "^9.39.1",
